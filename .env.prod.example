# SIWE / Cookies / CORS
COOKIE_DOMAIN=.example.com
COOKIE_SECURE=true
CORS_ORIGINS=https://panel.example.com
SIWE_NONCE_TTL_MIN=10
SIWE_ALLOWED_CHAIN_IDS=999,42161
