# Copy this file to a local untracked .env.prod for production.
# Never commit populated env files.

NODE_ENV=production

# Core runtime
DATABASE_URL=postgresql://mm:mm@postgres:5432/marketmaker?schema=public
ORCHESTRATION_MODE=queue
REDIS_URL=redis://redis:6379
API_RATE_LIMIT_REDIS_URL=redis://redis:6379

# Public web URL used by browser
NEXT_PUBLIC_API_URL=https://api.desk.uliquid.vip

# Optional server-side fallbacks inside web container
API_URL=http://api:8080
API_BASE_URL=http://api:8080

# WalletConnect / Web3 (build-time for web image)
NEXT_PUBLIC_WEB3_TARGET_CHAIN_ID=999
NEXT_PUBLIC_HYPEREVM_RPC_URL=https://rpc.hyperliquid.xyz/evm
NEXT_PUBLIC_HYPEREVM_EXPLORER_URL=https://app.hyperliquid.xyz/explorer
NEXT_PUBLIC_USDC_ADDRESS=0xb88339CB7199b77E23DB6E890353E22632Ba630f
USDC_ADDRESS=0xb88339CB7199b77E23DB6E890353E22632Ba630f
NEXT_PUBLIC_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
NEXT_PUBLIC_ARBITRUM_EXPLORER_URL=https://arbiscan.io
NEXT_PUBLIC_ARBITRUM_USDC_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831
ARBITRUM_USDC_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831
NEXT_PUBLIC_HYPERLIQUID_EXCHANGE_URL=https://api.hyperliquid.xyz
HYPERLIQUID_EXCHANGE_URL=https://api.hyperliquid.xyz
NEXT_PUBLIC_HYPERLIQUID_SYSTEM_ADDRESS=0x2222222222222222222222222222222222222222
HYPERLIQUID_SYSTEM_ADDRESS=0x2222222222222222222222222222222222222222
NEXT_PUBLIC_HYPERLIQUID_DEPOSIT_URL=https://app.hyperliquid.xyz/trade
HYPERLIQUID_DEPOSIT_URL=https://app.hyperliquid.xyz/trade
NEXT_PUBLIC_HYPERLIQUID_CORE_EVM_TRANSFER_URL=https://app.hyperliquid.xyz/portfolio
HYPERLIQUID_CORE_EVM_TRANSFER_URL=https://app.hyperliquid.xyz/portfolio
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_WEB3_ENABLE_ARBITRUM=1

# Contracts deploy (optional, used by scripts/deploy_contracts_vps.sh)
CONTRACTS_RPC_URL=https://rpc.hyperliquid.xyz/evm
CONTRACTS_CHAIN_ID=999
CONTRACTS_FORGE_BROADCAST_ARGS=--legacy
CONTRACTS_DEPLOY_OWNER=
CONTRACTS_USDC_ADDRESS=
CONTRACTS_PRIVATE_KEY=

# SIWE / Cookies / CORS
COOKIE_DOMAIN=.uliquid.vip
COOKIE_SECURE=true
CORS_ORIGINS=https://desk.uliquid.vip
SIWE_NONCE_TTL_MIN=10
SIWE_ALLOWED_CHAIN_IDS=999,42161
SIWE_ALLOWED_DOMAINS=desk.uliquid.vip
PANEL_BASE_URL=https://desk.uliquid.vip

# Trading / exchange rollout
BITGET_REST_BASE_URL=https://api.bitget.com
BITGET_PRODUCT_TYPE=USDT-FUTURES
BITGET_MARGIN_COIN=USDT
MANUAL_TRADING_SPOT_ENABLED=1
CEX_SPOT_DEFAULT_BACKEND=native
CEX_SPOT_BACKEND_OVERRIDES=bitget:ccxt,mexc:ccxt
CEX_SPOT_WRITE_ENABLED=0
CEX_SPOT_WRITE_OVERRIDES=mexc:1
MEXC_SPOT_ENABLED=0
MEXC_PERP_ENABLED=0
MEXC_REST_BASE_URL=https://api.mexc.com
MEXC_WS_URL=wss://contract.mexc.com/edge
BINANCE_SPOT_ENABLED=0
BINANCE_PERP_ENABLED=0
BINANCE_PERP_BASE_URL=https://fapi.binance.com

# Vault / execution
VAULT_EXECUTION_MODE=offchain_shadow
VAULT_ONCHAIN_CHAIN_ID=999
VAULT_ONCHAIN_RPC_URL=https://rpc.hyperliquid.xyz/evm
VAULT_ONCHAIN_FACTORY_ADDRESS=
VAULT_ONCHAIN_USDC_ADDRESS=0xb88339CB7199b77E23DB6E890353E22632Ba630f
VAULT_ONCHAIN_CONFIRMATIONS=2
VAULT_ONCHAIN_START_BLOCK=0
VAULT_ONCHAIN_INDEXER_MIN_BLOCK_SPAN=25
VAULT_ONCHAIN_INDEXER_RATE_LIMIT_BACKOFF_SECONDS=45
VAULT_ONCHAIN_INDEXER_RATE_LIMIT_MAX_SECONDS=300
VAULT_ONCHAIN_SIM_CHAIN_ID=31337
VAULT_ONCHAIN_SIM_RPC_URL=http://127.0.0.1:8545
VAULT_ONCHAIN_SIM_FACTORY_ADDRESS=
VAULT_ONCHAIN_SIM_USDC_ADDRESS=
VAULT_ONCHAIN_SIM_CONFIRMATIONS=0
VAULT_ONCHAIN_SIM_START_BLOCK=0
VAULT_ONCHAIN_INDEXER_INTERVAL_SECONDS=15
VAULT_ONCHAIN_INDEXER_MAX_BLOCK_SPAN=500
VAULT_ONCHAIN_INDEXER_LAG_ALERT_SECONDS=60
VAULT_ONCHAIN_INDEXER_LAG_ALERT_BLOCKS=20
VAULT_ONCHAIN_RECONCILIATION_INTERVAL_SECONDS=60
VAULT_ONCHAIN_RECONCILIATION_MASTER_LIMIT=100
VAULT_ONCHAIN_RECONCILIATION_BOT_LIMIT=200
BOT_VAULT_TRADING_RECONCILIATION_LAG_ALERT_SECONDS=120
RUNNER_AGENT_SECRET_PROVIDER=encrypted_env
HYPERLIQUID_AGENT_SECRETS_ENCRYPTED_JSON=
AGENT_SECRET_ENCRYPTION_KEY=

# AI / strategy service
AI_PROVIDER=disabled
AI_API_KEY=
AI_MODEL=gpt-4o-mini
# Salad proxy upstream host for http://salad-proxy:8088/v1
# Replace this with the current Salad inference host from your container endpoint.
SALAD_OPENAI_UPSTREAM_HOST=beet-ambrosia-una2kb4n1u45see3.salad.cloud
AI_TIMEOUT_MS=8000
AI_EXPLAINER_MAX_TOKENS=1400
AI_EXPLAINER_RETRY_MAX_TOKENS=2200
AI_GPT5_EXPLAINER_MAX_TOKENS=3200
AI_GPT5_EXPLAINER_RETRY_MAX_TOKENS=5200
AI_GPT5_EXPLAINER_MAX_ATTEMPTS=3
AI_GPT5_EXPLAINER_FINAL_MAX_TOKENS=8320
AI_CACHE_TTL_SEC=300
AI_RATE_LIMIT_PER_MIN=60
PREDICTION_AUTO_ENABLED=1
PREDICTION_AUTO_POLL_SECONDS=60
PREDICTION_AUTO_TEMPLATE_SCAN_LIMIT=300
PREDICTION_AUTO_MAX_RUNS_PER_CYCLE=25
PREDICTION_OUTCOME_HORIZON_BARS=12
PREDICTION_OUTCOME_EVAL_ENABLED=1
PREDICTION_OUTCOME_EVAL_POLL_SECONDS=60
PREDICTION_OUTCOME_EVAL_BATCH_SIZE=50
PY_STRATEGY_AUTH_TOKEN=change_me

# Queue / worker
QUEUE_PREFIX=utradevip
BOT_QUEUE_NAME=bots
WORKER_CONCURRENCY=10
WORKER_LOCK_DURATION_MS=60000
WORKER_STALLED_INTERVAL_MS=30000
WORKER_MAX_STALLED_COUNT=2
BOT_RATE_LIMIT_MAX=50
BOT_RATE_LIMIT_DURATION_MS=1000
BOT_JOB_ATTEMPTS=5
BOT_JOB_BACKOFF_MS=1000
GLOBAL_TRADING_ENABLED=true
BOT_CB_MAX_ERRORS=5
BOT_CB_WINDOW_SECONDS=300
BOT_CB_COOLDOWN_SECONDS=900
BOT_CB_ACTION=stop

# Python strategy/grid runtime
# Keep PY_STRATEGY_AUTH_TOKEN and PY_GRID_AUTH_TOKEN identical unless you intentionally operate them separately.
PY_STRATEGY_ENABLED=true
PY_STRATEGY_URL=http://py-strategy-service:9000
PY_STRATEGY_TIMEOUT_MS=1200
PY_STRATEGY_AUTH_TOKEN=change_me
PY_STRATEGY_CB_WINDOW_MS=60000
PY_STRATEGY_CB_MAX_FAILURES=5
PY_STRATEGY_CB_MAX_TIMEOUTS=3
PY_STRATEGY_CB_COOLDOWN_MS=60000
PY_GRID_ENABLED=true
PY_GRID_URL=http://py-strategy-service:9000
PY_GRID_AUTH_TOKEN=change_me
PY_GRID_TIMEOUT_MS=1500
PY_GRID_CB_WINDOW_MS=60000
PY_GRID_CB_MAX_FAILURES=5
PY_GRID_CB_COOLDOWN_MS=60000

# License gate (internal, subscription-backed)
LICENSE_ENFORCEMENT=off
LICENSE_STUB_ENABLED=on
LICENSE_SERVER_URL=https://license-server.uliquid.vip
LICENSE_CACHE_TTL_SECONDS=600
LICENSE_STUB_MAX_RUNNING_BOTS=3
LICENSE_STUB_MAX_BOTS_TOTAL=10
LICENSE_STUB_ALLOWED_EXCHANGES=bitget

# SMTP (invites)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=no-reply@uliquid.vip
SMTP_PASS=change_me
SMTP_FROM="uLiquid <no-reply@uliquid.vip>"
SMTP_SECURE=true
INVITE_BASE_URL=https://desk.uliquid.vip

# Telegram alerts (optional; DB settings can also be used)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Secrets and optional seed
SECRET_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ADMIN_EMAIL=admin@uliquid.vip
ADMIN_PASSWORD=ChangeMe123!
